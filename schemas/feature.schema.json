{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Albert Feature",
  "type": "object",
  "required": ["albertType", "albertVersion", "epicPath", "name", "stories"],
  "additionalProperties": false,
  "properties": {
    "albertType": { "const": "feature" },
    "albertVersion": { "const": 1 },
    "epicPath": { "type": "string" },
    "name": { "type": "string" },
    "stories": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Albert Environment Config",
  "type": "object",
  "required": ["albertType", "albertVersion", "name", "variables", "settings"],
  "additionalProperties": false,
  "properties": {
    "albertType": { "const": "env_config" },
    "albertVersion": { "const": 1 },
    "name": { "type": "string" },
    "variables": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "value", "enabled"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "value": { "type": "string" },
          "enabled": { "type": "boolean" }
        }
      }
    },
    "settings": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "timeoutMs": { "type": "number" },
        "followRedirects": { "type": "boolean" }
      }
    }
  }
}

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Albert Flow",
  "type": "object",
  "required": ["albertType", "albertVersion", "name", "steps"],
  "additionalProperties": false,
  "properties": {
    "albertType": { "const": "flow" },
    "albertVersion": { "const": 1 },
    "name": { "type": "string" },
    "steps": {
      "type": "array",
      "items": { "$ref": "#/definitions/flowStep" }
    }
  },
  "definitions": {
    "flowStep": {
      "type": "object",
      "required": ["id", "name", "requestPath", "enabled", "validate", "captures"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "requestPath": { "type": "string" },
        "enabled": { "type": "boolean" },
        "validate": { "type": "boolean" },
        "captures": {
          "type": "array",
          "items": { "$ref": "#/definitions/flowCapture" }
        }
      }
    },
    "flowCapture": {
      "type": "object",
      "required": ["variable", "source"],
      "additionalProperties": false,
      "properties": {
        "variable": { "type": "string" },
        "source": { "enum": ["body", "header", "status"] },
        "path": { "type": "string" }
      }
    }
  }
}

{
  "request": {
    "method": "GET",
    "urlPath": "/search",
    "queryParameters": {
      "api_key": { "equalTo": "demo-key-789" }
    }
  },
  "response": {
    "status": 200,
    "headers": { "Content-Type": "application/json" },
    "jsonBody": {
      "results": ["Ada Lovelace"],
      "query": "{{request.query.q}}"
    },
    "transformers": ["response-template"]
  }
}
